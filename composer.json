{
    "name": "j2commerce/j2commerce-tests",
    "description": "Development tooling and automated test suite for J2Commerce (Joomla 6).",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.64",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload-dev": {
        "psr-4": {
            "J2Commerce\\Component\\J2commerce\\Administrator\\": "administrator/components/com_j2commerce/src/",
            "J2Commerce\\Component\\J2commerce\\Site\\": "components/com_j2commerce/src/",
            "J2Commerce\\Library\\J2Commerce\\": "libraries/j2commerce/src/",
            "J2Commerce\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
