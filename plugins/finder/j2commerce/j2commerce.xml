    <version>6.0.7</version>
    <description>PLG_FINDER_J2COMMERCE_XML_DESCRIPTION</description>
    <namespace path="src">J2Commerce\Plugin\Finder\J2commerce</namespace>
    <files>
        <folder plugin="j2commerce">services</folder>
        <folder>src</folder>
    </files>
    <languages>
        <language tag="en-US">language/en-US/plg_finder_j2commerce.ini</language>
