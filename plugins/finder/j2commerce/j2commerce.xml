    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="redirect_to"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_FINDER_J2COMMERCE_REDIRECT_TO_LABEL"
                    description="PLG_FINDER_J2COMMERCE_REDIRECT_TO_DESC"
                    default="j2commerce"
                    filter="word"
                >
                    <option value="j2commerce">PLG_FINDER_J2COMMERCE_REDIRECT_PRODUCT</option>
                    <option value="article">PLG_FINDER_J2COMMERCE_REDIRECT_ARTICLE</option>
                </field>
                <field
                    name="exclude_linked_articles"
                    type="radio"
                    label="PLG_FINDER_J2COMMERCE_EXCLUDE_LINKED_ARTICLES_LABEL"
                    description="PLG_FINDER_J2COMMERCE_EXCLUDE_LINKED_ARTICLES_DESC"
                    layout="joomla.form.field.radio.switcher"
                    filter="integer"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="show_product_image"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_FINDER_J2COMMERCE_SHOW_PRODUCT_IMAGE_LABEL"
                    description="PLG_FINDER_J2COMMERCE_SHOW_PRODUCT_IMAGE_DESC"
                    default="1"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
