<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_J2COMMERCE_FILTER_SEARCH_LABEL"
            description="COM_J2COMMERCE_FILTER_SEARCH_VOUCHERS_DESC"
            hint="COM_J2COMMERCE_FILTER_SEARCH_VOUCHERS_LABEL"
            inputmode="search"
        />

        <field
            name="enabled"
            type="status"
            label="JOPTION_SELECT_PUBLISHED"
            onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        <field
            name="status"
            type="list"
            label="COM_J2COMMERCE_FILTER_VOUCHER_STATUS_LABEL"
            onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_STATUS</option>
            <option value="active">COM_J2COMMERCE_COUPON_ACTIVE</option>
            <option value="depleted">COM_J2COMMERCE_VOUCHER_STATUS_DEPLETED</option>
            <option value="not_yet_valid">COM_J2COMMERCE_VOUCHER_STATUS_NOT_YET_VALID</option>
            <option value="expired">COM_J2COMMERCE_COUPON_EXPIRED</option>
            <option value="disabled">COM_J2COMMERCE_DISABLED</option>
        </field>

        <field
            name="low_balance"
            type="list"
            label="COM_J2COMMERCE_FILTER_VOUCHER_LOW_BALANCE_LABEL"
            onchange="this.form.submit();"
        >
            <option value="">JALL</option>
            <option value="1">JYES</option>
        </field>

        <field
            name="unassigned"
            type="list"
            label="COM_J2COMMERCE_FILTER_VOUCHER_UNASSIGNED_LABEL"
            onchange="this.form.submit();"
        >
            <option value="">JALL</option>
            <option value="1">JYES</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.ordering ASC"
            onchange="this.form.submit();"
            validate="options"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.ordering ASC">COM_J2COMMERCE_HEADING_ORDERING_ASC</option>
            <option value="a.ordering DESC">COM_J2COMMERCE_HEADING_ORDERING_DESC</option>
            <option value="a.enabled ASC">COM_J2COMMERCE_HEADING_STATUS_ASC</option>
            <option value="a.enabled DESC">COM_J2COMMERCE_HEADING_STATUS_DESC</option>
            <option value="a.voucher_code ASC">COM_J2COMMERCE_HEADING_VOUCHER_CODE_ASC</option>
            <option value="a.voucher_code DESC">COM_J2COMMERCE_HEADING_VOUCHER_CODE_DESC</option>
            <option value="a.email_to ASC">COM_J2COMMERCE_HEADING_RECIPIENT_ASC</option>
            <option value="a.email_to DESC">COM_J2COMMERCE_HEADING_RECIPIENT_DESC</option>
            <option value="a.voucher_value ASC">COM_J2COMMERCE_HEADING_VOUCHER_VALUE_ASC</option>
            <option value="a.voucher_value DESC">COM_J2COMMERCE_HEADING_VOUCHER_VALUE_DESC</option>
            <option value="remaining_balance ASC">COM_J2COMMERCE_HEADING_REMAINING_BALANCE_ASC</option>
            <option value="remaining_balance DESC">COM_J2COMMERCE_HEADING_REMAINING_BALANCE_DESC</option>
            <option value="uses_count ASC">COM_J2COMMERCE_HEADING_USES_ASC</option>
            <option value="uses_count DESC">COM_J2COMMERCE_HEADING_USES_DESC</option>
            <option value="derived_status ASC">COM_J2COMMERCE_HEADING_VOUCHER_STATUS_ASC</option>
            <option value="derived_status DESC">COM_J2COMMERCE_HEADING_VOUCHER_STATUS_DESC</option>
            <option value="a.valid_from ASC">COM_J2COMMERCE_HEADING_VALID_FROM_ASC</option>
            <option value="a.valid_from DESC">COM_J2COMMERCE_HEADING_VALID_FROM_DESC</option>
            <option value="a.valid_to ASC">COM_J2COMMERCE_HEADING_VALID_TO_ASC</option>
            <option value="a.valid_to DESC">COM_J2COMMERCE_HEADING_VALID_TO_DESC</option>
            <option value="a.created_on ASC">COM_J2COMMERCE_HEADING_CREATED_ON_ASC</option>
            <option value="a.created_on DESC">COM_J2COMMERCE_HEADING_CREATED_ON_DESC</option>
            <option value="a.j2commerce_voucher_id ASC">COM_J2COMMERCE_HEADING_ID_ASC</option>
            <option value="a.j2commerce_voucher_id DESC">COM_J2COMMERCE_HEADING_ID_DESC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
